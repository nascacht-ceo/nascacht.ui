{
  "name": "nascacht-ui",
  "version": "0.1.0",
  "description": "Framework-agnostic dockable widget library built on Lit web components",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/esm/index.cjs"
    },
    "./bundle": {
      "import": "./dist/bundle/index.js",
      "types": "./dist/esm/index.d.ts"
    }
  },
  "main": "./dist/esm/index.cjs",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "test": "wtr",
    "test:watch": "wtr --watch",
    "test:e2e": "playwright test",
    "storybook": "storybook dev -p 6006",
    "build:storybook": "storybook build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts"
  },
  "peerDependencies": {
    "@lit/context": "^1.1.0",
    "dockview-core": "^4.0.0",
    "lit": "^3.0.0"
  },
  "devDependencies": {
    "@lit/context": "^1.1.0",
    "@open-wc/testing": "^4.0.0",
    "@playwright/test": "^1.44.0",
    "@storybook/addon-a11y": "^8.1.0",
    "@storybook/addon-essentials": "^8.1.0",
    "@storybook/web-components": "^8.1.0",
    "@storybook/web-components-vite": "^8.1.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@web/dev-server-esbuild": "^1.0.0",
    "@web/test-runner": "^0.19.0",
    "@web/test-runner-playwright": "^0.11.0",
    "dockview-core": "^4.0.0",
    "eslint": "^8.57.0",
    "lit": "^3.0.0",
    "storybook": "^8.1.0",
    "tsup": "^8.1.0",
    "typescript": "^5.5.0"
  },
  "keywords": [
    "web-components",
    "lit",
    "dockview",
    "widgets",
    "dashboard"
  ],
  "license": "MIT"
}
